SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
EMAIL_FROM=you@example.com
EMAIL_TO=you@example.com
EMAIL_USER=you@example.com
EMAIL_PASS=replace_with_email_app_password

TOTAL_BUDGET_USD=100
TOP_MOVE_COUNT=5
RISK_BUCKET_COUNT=3

MAX_POSITION_PCT=0.40
RISKY_ALLOCATION_MULTIPLIER=0.0
NO_TRADE_ALLOCATION_MULTIPLIER=0.0
CONFIDENCE_TARGET=0.10
EDGE_TARGET=0.10

TRADING_ENABLED=false
TRADING_DRY_RUN=true
TRADE_MAX_DAILY_NOTIONAL_USD=100
TRADE_MAX_PER_TRADE_USD=20
TRADE_MIN_ORDER_NOTIONAL_USD=1
TRADE_MAX_OPEN_ORDERS=10
TRADE_MIN_CONTRACTS=1
TRADE_MIN_EDGE=0.00
TRADE_MIN_CONFIDENCE=0.00
TRADE_MAX_SPREAD=0.08
TRADE_ALLOW_RISKY=false
TRADE_ALLOW_NO_TRADE_FLAG=false
TRADE_ALLOWED_MARKET_TYPES=high,low,rain,snow,wind
TRADE_ORDER_TTL_SECONDS=60
TRADE_LEDGER_PATH=history/trade_ledger.csv
TRADE_PRICE_IN_CENTS=false

KALSHI_BASE_URL=https://api.elections.kalshi.com/trade-api/v2
KALSHI_TIMEOUT_SEC=20
KALSHI_ORDER_PATH=/portfolio/orders

# Signed auth (recommended for live):
KALSHI_KEY_ID=replace_with_api_key_id
KALSHI_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nreplace_with_pem_contents\n-----END PRIVATE KEY-----"
KALSHI_PRIVATE_KEY_PATH=

# Optional non-signed auth fallback:
KALSHI_BEARER_TOKEN=
KALSHI_API_KEY=
KALSHI_AUTH_HEADER=
KALSHI_AUTH_VALUE=
